NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# LLM provider (default: deepseek)
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_DEFAULT_MODEL=deepseek-v4-flash

# Resume tailor (Phase 4)
RESUME_TAILOR_MODEL=deepseek-v4-pro
RESUME_TAILOR_FALLBACK_MODEL=deepseek-v4-flash
RESUME_TAILOR_THINKING_MODE=false

# Resend (Phase 5 — outreach sending)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=you@yourdomain.com

# Future providers (not implemented yet — see adapters/gemini.adapter.sketch.ts)
# GEMINI_API_KEY=
# OPENAI_API_KEY=
